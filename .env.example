# =============================================
# RecordAI — Variables de entorno
# Copiar este archivo como .env y completar los valores
# En Railway: configurar cada variable en el dashboard del servicio
# =============================================

# --- API (servicio "api" en Railway) ---

# Supabase
SUPABASE_URL=https://<proyecto>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>

# Autenticación
JWT_SECRET=<string_aleatorio_minimo_32_caracteres>

# Redis (Upstash o similar)
REDIS_URL=redis://default:<password>@<host>:<port>

# WhatsApp (Meta Cloud API — cuenta centralizada del owner)
# META_SYSTEM_USER_TOKEN es el token principal (System User permanente de tu WABA)
# WHATSAPP_ACCESS_TOKEN se mantiene por compatibilidad; META_SYSTEM_USER_TOKEN tiene prioridad
WHATSAPP_PHONE_NUMBER_ID=<phone_number_id_default>   # fallback para tenants sin número propio
WHATSAPP_ACCESS_TOKEN=<permanent_access_token>       # usar mismo valor que META_SYSTEM_USER_TOKEN
WHATSAPP_VERIFY_TOKEN=<token_verificacion_webhook>
WHATSAPP_TEMPLATE_REMINDER=confirmacion_turnos
WHATSAPP_TEMPLATE_LANGUAGE=es    # Language code for Meta templates (es, es_AR, en, etc.)

# Meta Coexistence — para que cada tenant conecte su propio número
META_APP_ID=<facebook_app_id>
META_APP_SECRET=<facebook_app_secret>          # requerido para verificar firma HMAC del webhook
META_SYSTEM_USER_TOKEN=<system_user_token>     # System User Token permanente (no expira)
META_BUSINESS_ID=<meta_business_id>
META_GRAPH_VERSION=v21.0
META_WA_CONFIG_ID=<embedded_signup_config_id>  # requerido solo para Embedded Signup (path A)

# Google Calendar OAuth
GOOGLE_CLIENT_ID=<client_id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<client_secret>

# Wasender (alternativa WhatsApp, opcional)
WASENDER_API_KEY=

# URLs
BASE_URL=https://<url-api>.railway.app         # URL pública de la API
CORS_ORIGIN=https://<url-web>.railway.app      # URL pública del frontend

# Puerto (Railway lo inyecta automáticamente)
PORT=3001

NODE_ENV=production

# --- Web (servicio "web" en Railway) ---

NEXT_PUBLIC_API_URL=https://<url-api>.railway.app   # URL pública de la API
ALLOWED_ORIGINS=<url-web>.railway.app               # Dominio del frontend (sin https://)
NEXT_PUBLIC_META_APP_ID=<facebook_app_id>           # requerido para Embedded Signup (path A)
NEXT_PUBLIC_META_WA_CONFIG_ID=<embedded_signup_config_id>
