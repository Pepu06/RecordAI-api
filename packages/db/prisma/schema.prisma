generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  staff
}

enum AppointmentStatus {
  pending
  notified
  confirmed
  cancelled
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageType {
  confirmation
  reminder
  follow_up
  reply
}

enum MessageStatus {
  sent
  delivered
  read
  failed
}

enum SubscriptionPlan {
  trial
  inicial
  profesional
  custom
}

enum SubscriptionStatus {
  active
  cancelled
  past_due
  trial_expired
}

model Tenant {
  id                     String   @id @default(cuid())
  name                   String
  plan                   String   @default("free")
  whatsappProvider       String?  @default("meta")
  whatsappPhoneNumberId  String?
  whatsappAccessToken    String?
  wasender_api_key       String?
  wasenderConnected      Boolean  @default(false)
  businessName           String?
  timezone               String?  @default("America/Argentina/Buenos_Aires")
  reminderType           String?  @default("day_before")
  reminderTime           String?  @default("10:00")
  messageTemplate        String?
  adminWhatsapp          String?
  reportDays             String?  @default("1,2,3,4,5")
  reportMorningTime      String?
  reportEveningTime      String?
  locationMode           String?  @default("fixed")
  location               String?
  trialEndsAt            DateTime?
  messagesSentThisMonth  Int      @default(0)
  subscriptionId         String?
  createdAt              DateTime @default(now())

  users             User[]
  contacts          Contact[]
  services          Service[]
  appointments      Appointment[]
  availabilityRules AvailabilityRule[]
  messageLogs       MessageLog[]
  subscription      Subscription?
  usageRecords      UsageRecord[]
  paymentProofs     PaymentProof[]
}

model User {
  id                    String   @id @default(cuid())
  tenantId              String
  email                 String   @unique
  passwordHash          String?
  role                  UserRole @default(staff)
  googleAccessToken     String?
  googleRefreshToken    String?
  emailVerified         Boolean  @default(false)
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  googleReconnectRequired Boolean @default(false)
  createdAt             DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  availabilityRules AvailabilityRule[]

  @@index([tenantId])
}

model Contact {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  phone    String
  notes    String?
  createdAt DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId])
}

model Service {
  id              String  @id @default(cuid())
  tenantId        String
  name            String
  durationMinutes Int
  price           Decimal @default(0)
  createdAt       DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId])
}

model Appointment {
  id                 String            @id @default(cuid())
  tenantId           String
  contactId          String
  serviceId          String
  userId             String
  scheduledAt        DateTime
  status             AppointmentStatus @default(pending)
  notes              String?
  reminderSentAt     DateTime?
  confirmationSentAt DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id])
  service     Service      @relation(fields: [serviceId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  messageLogs MessageLog[]

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, status])
}

model AvailabilityRule {
  id         String  @id @default(cuid())
  tenantId   String
  userId     String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model MessageLog {
  id            String           @id @default(cuid())
  tenantId      String
  appointmentId String
  type          MessageType
  direction     MessageDirection @default(outbound)
  status        MessageStatus    @default(sent)
  sentAt        DateTime         @default(now())
  waMessageId   String?

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([appointmentId])
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String             @unique
  plan               SubscriptionPlan   @default(trial)
  status             SubscriptionStatus @default(active)
  mpSubscriptionId   String?            @unique
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([mpSubscriptionId])
}

model UsageRecord {
  id                  String   @id @default(cuid())
  tenantId            String
  year                Int
  month               Int
  messagesSent        Int      @default(0)
  appointmentsCreated Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year, month])
  @@index([tenantId])
}


enum PaymentProofStatus {
  pending
  approved
  rejected
}

model PaymentProof {
  id          String             @id @default(cuid())
  tenantId    String
  plan        SubscriptionPlan
  amount      Decimal            @db.Decimal(10, 2)
  imageUrl    String
  status      PaymentProofStatus @default(pending)
  notes       String?
  reviewedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("PaymentProof")
}
